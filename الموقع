  document.getElementById('bookingSuccess').style.display='block';
  setTimeout(()=>{closeModal('booking');document.getElementById('bookingSuccess').style.display='none'},2000);
}

function submitConsult(){
  const n=document.getElementById('consultName').value.trim();
  const p=document.getElementById('consultPhone').value.trim();
  const m=document.getElementById('consultMsg').value.trim();
  if(!n||!p){alert('يرجى إدخال الاسم ورقم الجوال');return}
  const msg=`💡 *طلب استشارة مجانية*\n\n👤 الاسم: ${n}\n📞 الجوال: ${p}\n📝 الاستفسار: ${m||'غير محدد'}`;
  window.open(`https://wa.me/${WA}?text=${encodeURIComponent(msg)}`, '_blank');
  document.getElementById('consultSuccess').style.display='block';
  setTimeout(()=>{closeModal('consult');document.getElementById('consultSuccess').style.display='none'},2000);
}

let selStars=0;
function setStars(v){
  selStars=v;
  document.querySelectorAll('.star').forEach((s,i)=>{s.classList.toggle('active',(5-i)<=v)});
}

function submitReview(){
  const n=document.getElementById('reviewName').value.trim();
  const t=document.getElementById('reviewText').value.trim();
  if(!n||!t){alert('يرجى إدخال اسمك وتقييمك');return}
  if(!selStars){alert('يرجى اختيار عدد النجوم');return}
  const msg=`⭐ *تقييم جديد*\n\n👤 الاسم: ${n}\n${'★'.repeat(selStars)}${'☆'.repeat(5-selStars)}\n💬 ${t}`;
  window.open(`https://wa.me/${WA}?text=${encodeURIComponent(msg)}`, '_blank');
  const list=document.getElementById('reviewsList');
  const card=document.createElement('div');card.className='review-card';
  card.innerHTML=`<div class="review-stars">${'★'.repeat(selStars)}</div><p class="review-text">${t}</p><div class="reviewer"><div class="reviewer-avatar">${n[0]}</div><div><div class="reviewer-name">${n}</div><div class="reviewer-loc">جدة</div></div></div>`;
  list.insertBefore(card,list.firstChild);
  document.getElementById('reviewName').value='';document.getElementById('reviewText').value='';setStars(0);
  document.getElementById('reviewSuccess').style.display='block';
  setTimeout(()=>{document.getElementById('reviewSuccess').style.display='none'},3000);
}

function toggleFaq(el){
  const item=el.parentElement;
  const ans=item.querySelector('.faq-a');
  const isOpen=item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(i=>{i.classList.remove('open');i.querySelector('.faq-a').style.maxHeight='0'});
  if(!isOpen){item.classList.add('open');ans.style.maxHeight=ans.scrollHeight+'px'}
}

function showArea(dir){
  document.querySelectorAll('.areas-panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.area-tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('area-'+dir).classList.add('active');
  event.target.classList.add('active');
}
</script>
